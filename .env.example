# Root environment reference for Chapter 4 Docker Compose deployment.
# Service-specific values remain in each service's `.env.example`.

# Gateway
GATEWAY_PORT=8080

# Frontend
FRONTEND_PORT=3000

# Public backend service ports
PRODUCT_SERVICE_PORT=8001
USER_SERVICE_PORT=8002
CART_SERVICE_PORT=8003
ORDER_SERVICE_PORT=8004
PAYMENT_SERVICE_PORT=8005
SHIPPING_SERVICE_PORT=8006
AI_SERVICE_PORT=8007

# Databases and dependencies
PRODUCT_DB_PORT=5432
AI_DB_PORT=5433
USER_DB_PORT=3307
CART_DB_PORT=3308
ORDER_DB_PORT=3309
PAYMENT_DB_PORT=3310
SHIPPING_DB_PORT=3311
NEO4J_HTTP_PORT=7474
NEO4J_BOLT_PORT=7687

# Shared security values used across the compose stack
JWT_SIGNING_KEY=shared-jwt-signing-key
INTERNAL_SERVICE_JWT_SECRET=internal-service-secret
INTERNAL_SERVICE_JWT_ALGORITHM=HS256
INTERNAL_SERVICE_ISSUER=order-service

# Notes
# - Root `docker-compose.yml` is the authoritative stack definition.
# - Detailed service config is still defined in:
#   - `user-service/.env.example`
#   - `product-service/.env.example`
#   - `cart-service/.env.example`
#   - `order-service/.env.example`
#   - `payment-service/.env.example`
#   - `shipping-service/.env.example`
#   - `ai-service/.env.example`
